{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -B -S \"${CLAUDE_PROJECT_DIR:-$PWD}\"/.claude/bin/hook_spawn_budget.py",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -B -S \"${CLAUDE_PROJECT_DIR:-$PWD}\"/.claude/bin/hook_write_scope_guard.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python3 -B -S \"${CLAUDE_PROJECT_DIR:-$PWD}\"/.claude/bin/hook_docs_discrepancy_check.py",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -B -S \"${CLAUDE_PROJECT_DIR:-$PWD}\"/.claude/bin/hook_update_ledger.py",
            "timeout": 15
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -B -S \"${CLAUDE_PROJECT_DIR:-$PWD}\"/.claude/bin/hook_capture_subagent_stop.py",
            "timeout": 45
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -B -S \"${CLAUDE_PROJECT_DIR:-$PWD}\"/.claude/bin/hook_session_context.py",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
