File: frontend/src/features/audit/data/logger.ts
Gate: const VERBOSE = import.meta.env.VITE_ENABLE_VERBOSE_LOGGING === 'true'

export function logVerbose(tag: string, data?: unknown): void {
  if (!VERBOSE) return;  // ← gate: nothing emitted when false
  console.info(`[audit] ${tag}`, data ?? '');
}

export function logWarn(tag: string, data?: unknown): void {
  console.warn(`[audit] ${tag}`, data ?? '');  // ← always emitted
}

export function logError(tag: string, data?: unknown): void {
  console.error(`[audit] ${tag}`, data ?? '');  // ← always emitted
}

