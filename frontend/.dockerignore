# frontend/.dockerignore — Frontend build context ignore
#
# Slice: P00-S02-T001 — Docker compose services (Rancher-ready)
# Phase: P00 — Scaffold + Design System
#
# Build context for frontend is ./frontend/ (set in docker-compose.yml).
# All paths below are relative to frontend/.

# ── Secrets / environment ─────────────────────────────────────────────────────
.env
.env.*
*.env

# ── Node modules — excluded so builder stage runs npm ci from scratch ─────────
node_modules/

# ── Build output — excluded from build context (built inside container) ───────
dist/
build/

# ── Vite / tooling artifacts ──────────────────────────────────────────────────
.vite/
coverage/
.nyc_output/

# ── Testing ───────────────────────────────────────────────────────────────────
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__/
vitest.config.*

# ── IDE / editors ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── TypeScript caches ─────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── Temporary ────────────────────────────────────────────────────────────────
*.tmp
*.bak
*.orig
