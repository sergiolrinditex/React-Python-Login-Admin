# backend/.dockerignore — Backend build context ignore
#
# Slice: P00-S02-T001 — Docker compose services (Rancher-ready)
# Phase: P00 — Scaffold + Design System
#
# Build context for backend is ./backend/ (set in docker-compose.yml).
# All paths below are relative to backend/.

# ── Secrets / environment ─────────────────────────────────────────────────────
.env
.env.*
*.env

# ── Python virtual environments ───────────────────────────────────────────────
.venv/
.venv-*/
venv/
venv-*/

# ── Python build artifacts ────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── Testing / coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
junit*.xml

# ── Type checking / linting ──────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/

# ── IDE / editors ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ── Alembic version artifacts (not needed in image; migrations run at startup) ──
# Note: alembic/ directory IS included (needed for migration runs inside container)
# Only exclude generated artifacts, not the migration scripts themselves.

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
*.pid

# ── Temporary ────────────────────────────────────────────────────────────────
*.tmp
*.bak
*.orig
