# .env.example — Hilo People environment variable template
#
# Slice: P00-S01-T001 — Repo scaffold + scripts + env
# Phase: P00 — Scaffold + Design System
# Updated: P01-S01-T002 — Aligned keys to TECHNICAL_GUIDE §11.1
#
# HOW TO USE:
#   cp .env.example .env
#   Edit .env with real values for your environment.
#   .env is gitignored and must NEVER be committed (secrets must not appear in source).
#
# Variable naming reference:
#   - HILO_PEOPLE_TECHNICAL_GUIDE.md §11.1 (canonical env var contract)
#   - scripts/dev-restart.profile.sh (port names: API_PORT, FRONT_PORT)
#   - docs/source-of-truth/STACK_PROFILE.yaml

# ---------------------------------------------------------------------------
# Server ports
# ---------------------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000
FRONT_PORT=5173

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_VERSION=0.1.0
ENABLE_VERBOSE_LOGGING=false

# ---------------------------------------------------------------------------
# Database (PostgreSQL + pgvector + pgcrypto)
# First migration added in P01-S01-T001; connection string format:
#   postgresql+asyncpg://user:password@host:5432/dbname
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://hilopeople:<change-me>@localhost:5432/hilopeople_dev

# ---------------------------------------------------------------------------
# Auth (JWT RS256 — implemented in P01-S02-T001)
# Renamed from JWT_SECRET (single HMAC) to JWT_PRIVATE_KEY + JWT_PUBLIC_KEY
# (asymmetric RS256, per TECHNICAL_GUIDE §10.2 + §11.1, aligned in P01-S01-T002).
#
# DEV-ONLY PLACEHOLDER: generate a real keypair with:
#   openssl genrsa -out /tmp/jwt_private.pem 2048
#   openssl rsa -in /tmp/jwt_private.pem -pubout -out /tmp/jwt_public.pem
# Then copy the PEM content (including BEGIN/END lines) into the values below.
# In production, inject via secret manager (never commit real keys).
#
# The values below are placeholder strings — the backend will start but JWT
# signing will fail until replaced by a real RSA keypair (P01-S02-T001 gate).
# ---------------------------------------------------------------------------
JWT_PRIVATE_KEY=<dev-rsa-private-key-pem-placeholder>
JWT_PUBLIC_KEY=<dev-rsa-public-key-pem-placeholder>
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=604800

# ---------------------------------------------------------------------------
# Redis / Celery (async jobs — added in T003)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# ---------------------------------------------------------------------------
# Security — provider key encryption (added in T003)
# Renamed from PROVIDER_ENCRYPTION_KEY → ENCRYPTION_KEY in P01-S01-T002 (§11.1).
# Master key for Fernet-encrypted provider API keys stored in DB.
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ---------------------------------------------------------------------------
ENCRYPTION_KEY=<change-me>

# ---------------------------------------------------------------------------
# LiteLLM (AI gateway — added in T003)
# LITELLM_PROXY_BASE_URL renamed → LITELLM_BASE_URL in P01-S01-T002 (§11.1).
# docker-compose.yml backend+worker environment blocks updated in same slice.
# ---------------------------------------------------------------------------
LITELLM_MASTER_KEY=<change-me>
LITELLM_BASE_URL=http://localhost:4000

# ---------------------------------------------------------------------------
# Storage / S3-compatible (added in T003)
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=<change-me>
AWS_SECRET_ACCESS_KEY=<change-me>
AWS_REGION=eu-west-1
# Renamed from S3_BUCKET_RAG_DOCUMENTS → S3_BUCKET_DOCUMENTS in P01-S01-T002 (§11.1).
S3_BUCKET_DOCUMENTS=hilopeople-rag-documents-dev

# ---------------------------------------------------------------------------
# Mail (Resend — added in T003)
# ---------------------------------------------------------------------------
RESEND_API_KEY=<change-me>
MAIL_FROM_ADDRESS=noreply@hilopeople.example.com
MAIL_FROM_NAME=Hilo People

# ---------------------------------------------------------------------------
# CORS (comma-separated allowed origins for production)
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------------------------------------------------------------------------
# Observability (added in T003)
# ---------------------------------------------------------------------------
SENTRY_DSN=<change-me>

# ---------------------------------------------------------------------------
# Docker Compose / Container infrastructure (added in P00-S02-T001)
# These vars are consumed by docker-compose.yml and the container runtime.
# They are NOT used by the backend pydantic-settings directly (they are
# compose interpolation vars), EXCEPT for DATABASE_URL and REDIS_URL which
# the compose file derives from POSTGRES_* vars to override the host defaults.
# ---------------------------------------------------------------------------

# PostgreSQL service credentials (used by compose to init the postgres container)
POSTGRES_USER=hilopeople
POSTGRES_PASSWORD=<change-me>
POSTGRES_DB=hilopeople_dev

# MinIO service credentials (S3-compatible storage for dev)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=<change-me>

# AWS endpoint override — points boto3 to local MinIO instead of real AWS S3
# This var IS consumed by backend config (core/config.py in P02-S06-T001).
AWS_ENDPOINT_URL=http://minio:9000

# LiteLLM master key (proxy auth — set the same value in both backend and litellm)
# Already declared above as LITELLM_MASTER_KEY in AI gateway block.
# Reference here so compose readers see it alongside other compose vars.

# i18n / feature flags (§11.1 canonical vars, uncommented in P01-S01-T002)
DEFAULT_LANGUAGE=es
MAX_UPLOAD_MB=25
MCP_ALLOWLIST_DOMAINS=localhost

# Image build metadata (used by 'docker compose build' via ARG)
IMAGE_TAG=dev
BUILD_VERSION=0.1.0
