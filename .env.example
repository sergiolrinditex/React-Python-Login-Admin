# .env.example — Hilo People environment variable template
#
# Slice: P00-S01-T001 — Repo scaffold + scripts + env
# Phase: P00 — Scaffold + Design System
# Updated: P01-S01-T002 — Aligned keys to TECHNICAL_GUIDE §11.1
# Updated: P01-S01-T004 — DATABASE_URL host port native dev fix (5432→5433)
# Updated: P00-S02-T013 — Replaced <...> angle-bracket placeholders with bash-safe literals
#
# HOW TO USE:
#   cp .env.example .env
#   Edit .env with real values for your environment.
#   .env is gitignored and must NEVER be committed (secrets must not appear in source).
#
# Variable naming reference:
#   - HILO_PEOPLE_TECHNICAL_GUIDE.md §11.1 (canonical env var contract)
#   - scripts/dev-restart.profile.sh (port names: API_PORT, FRONT_PORT)
#   - docs/source-of-truth/STACK_PROFILE.yaml

# ---------------------------------------------------------------------------
# Server ports
# ---------------------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000
FRONT_PORT=5173

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_VERSION=0.1.0
ENABLE_VERBOSE_LOGGING=false

# ---------------------------------------------------------------------------
# Database (PostgreSQL + pgvector + pgcrypto)
# First migration added in P01-S01-T001; connection string format:
#   postgresql+asyncpg://user:password@host:port/dbname
#
# TWO VALID USAGE MODES — choose the one that applies to your use case:
#
#   Mode A — Native dev (uvicorn on host, alembic/pytest from cd backend/):
#     Host process connects to hilo-postgres via the mapped host port.
#     docker-compose.yml maps host 5433 → container 5432 ("5433:5432" on line ~72).
#     Port 5432 on the host is occupied by a sibling project's postgres container.
#     Use DATABASE_URL below (localhost:5433) — this is the default for native dev.
#     POSTGRES_PASSWORD must match the value used when docker-compose initialized
#     the hilo-postgres container. After changing POSTGRES_PASSWORD here, run:
#       bash scripts/dev-restart.sh --reset   (rebuilds the container from scratch)
#
#   Mode B — Inside compose (backend container, worker container):
#     Containers reach postgres via the internal service name "postgres" on port 5432.
#     This value is set directly in docker-compose.yml's backend + worker environment
#     blocks and does NOT come from this .env file.
#     You do NOT need to change DATABASE_URL here for Mode B.
#     The compose line is: DATABASE_URL=postgresql+asyncpg://...@postgres:5432/...
#
# The value below is Mode A (native dev) — it is what backend/app/core/config.py
# reads when running outside of docker-compose (uvicorn from project root, pytest
# from cd backend/, alembic from cd backend/).
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://hilopeople:change-me@localhost:5433/hilopeople_dev

# ---------------------------------------------------------------------------
# Auth (JWT RS256 — implemented in P01-S02-T001)
# Renamed from JWT_SECRET (single HMAC) to JWT_PRIVATE_KEY + JWT_PUBLIC_KEY
# (asymmetric RS256, per TECHNICAL_GUIDE §10.2 + §11.1, aligned in P01-S01-T002).
#
# DEV-ONLY PLACEHOLDER: generate a real keypair with:
#   openssl genrsa -out /tmp/jwt_private.pem 2048
#   openssl rsa -in /tmp/jwt_private.pem -pubout -out /tmp/jwt_public.pem
# Then copy the PEM content (including BEGIN/END lines) into the values below.
# In production, inject via secret manager (never commit real keys).
#
# The values below are placeholder strings — the backend will start but JWT
# signing will fail until replaced by a real RSA keypair (P01-S02-T001 gate).
# ---------------------------------------------------------------------------
JWT_PRIVATE_KEY=dev-rsa-private-key-pem-placeholder
JWT_PUBLIC_KEY=dev-rsa-public-key-pem-placeholder
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=604800

# ---------------------------------------------------------------------------
# Redis / Celery (async jobs — added in T003)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# ---------------------------------------------------------------------------
# Security — provider key encryption (added in T003)
# Renamed from PROVIDER_ENCRYPTION_KEY → ENCRYPTION_KEY in P01-S01-T002 (§11.1).
# Master key for Fernet-encrypted provider API keys stored in DB.
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# scripts/setup-from-scratch.sh auto-generates a real Fernet key when this placeholder is detected.
# ---------------------------------------------------------------------------
ENCRYPTION_KEY=dev-encryption-key-placeholder

# ---------------------------------------------------------------------------
# LiteLLM (AI gateway — added in T003)
# LITELLM_PROXY_BASE_URL renamed → LITELLM_BASE_URL in P01-S01-T002 (§11.1).
# docker-compose.yml backend+worker environment blocks updated in same slice.
# ---------------------------------------------------------------------------
LITELLM_MASTER_KEY=change-me
LITELLM_BASE_URL=http://localhost:4000

# ---------------------------------------------------------------------------
# Storage / S3-compatible (added in T003)
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
AWS_REGION=eu-west-1
# Renamed from S3_BUCKET_RAG_DOCUMENTS → S3_BUCKET_DOCUMENTS in P01-S01-T002 (§11.1).
S3_BUCKET_DOCUMENTS=hilopeople-rag-documents-dev

# ---------------------------------------------------------------------------
# Mail (Resend — added in T003)
# ---------------------------------------------------------------------------
RESEND_API_KEY=change-me
MAIL_FROM_ADDRESS=noreply@hilopeople.example.com
MAIL_FROM_NAME="Hilo People"

# ---------------------------------------------------------------------------
# CORS (comma-separated allowed origins for production)
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------------------------------------------------------------------------
# Observability (added in T003)
# ---------------------------------------------------------------------------
SENTRY_DSN=change-me

# ---------------------------------------------------------------------------
# Docker Compose / Container infrastructure (added in P00-S02-T001)
# These vars are consumed by docker-compose.yml and the container runtime.
# They are NOT used by the backend pydantic-settings directly (they are
# compose interpolation vars), EXCEPT for DATABASE_URL and REDIS_URL which
# the compose file derives from POSTGRES_* vars to override the host defaults.
# ---------------------------------------------------------------------------

# PostgreSQL service credentials (used by compose to init the hilo-postgres container)
# IMPORTANT co-dependency: POSTGRES_PASSWORD here and the password in DATABASE_URL above
# MUST be the same value. When compose initializes hilo-postgres it uses POSTGRES_PASSWORD;
# when alembic/pytest/uvicorn connect in native dev (Mode A) they use the DATABASE_URL
# password. After changing either one, run: bash scripts/dev-restart.sh --reset
POSTGRES_USER=hilopeople
POSTGRES_PASSWORD=change-me
POSTGRES_DB=hilopeople_dev

# MinIO service credentials (S3-compatible storage for dev)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me

# AWS endpoint override — points boto3 to local MinIO instead of real AWS S3
# This var IS consumed by backend config (core/config.py in P02-S06-T001).
AWS_ENDPOINT_URL=http://minio:9000

# LiteLLM master key (proxy auth — set the same value in both backend and litellm)
# Already declared above as LITELLM_MASTER_KEY in AI gateway block.
# Reference here so compose readers see it alongside other compose vars.

# i18n / feature flags (§11.1 canonical vars, uncommented in P01-S01-T002)
DEFAULT_LANGUAGE=es
MAX_UPLOAD_MB=25
MCP_ALLOWLIST_DOMAINS=localhost

# Image build metadata (used by 'docker compose build' via ARG)
IMAGE_TAG=dev
BUILD_VERSION=0.1.0

# ---------------------------------------------------------------------------
# Verification bundle secrets (P00-S02-T005 — bootstrap-only, NOT runtime)
# Updated by: P00-S02-T005 — Replace synthetic verification bundle
# ---------------------------------------------------------------------------
# These keys are consumed ONLY by the seed loader CLI at bootstrap time.
# They MUST be placed in .env.local (gitignored), NOT in .env.
# See data/verification/MANIFEST.json and data/verification/admin_ai/providers.json.
# OBTAIN: Google keys from Google AI Studio dashboard; OpenAI from platform.openai.com.
VERIFICATION_GEMINI_API_KEY=
VERIFICATION_GEMINI_API_KEY_BACKUP=
VERIFICATION_OPENAI_API_KEY=
# Generate with: python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
VERIFICATION_LITELLM_MASTER_KEY=
# Placeholder until P02-S07 issues real MCP token
VERIFICATION_MCP_TOKEN_SANDBOX=

# ---------------------------------------------------------------------------
# Auth sign-up: corporate email domain allowlist (P01-S02-T001)
# ---------------------------------------------------------------------------
# Comma-separated list of allowed email domains for sign-up.
# Empty (default) = permissive in dev — any email domain is accepted.
# Non-empty example: CORPORATE_EMAIL_DOMAINS=hilo.com,hilopeople.com
# Production MUST set this to the company's real domain(s).
# Source: instrucciones.md §3.1 + HILO_PEOPLE_TECHNICAL_GUIDE.md §11.1 (P01-S02-T001)
CORPORATE_EMAIL_DOMAINS=
