# Hilo People — environment variable template.
#
# Slice:  P00-S01-T001 — Repo scaffold + scripts + env
# Phase:  P00 Scaffold + Design System
# Source: TECHNICAL_GUIDE §11.1 Variables de entorno adicionales
#         01-non-negotiables.md §Logging
#
# Updated: P00-S02-T001 — Docker compose services
#   Added: POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB (required by postgres
#          service in docker-compose.yml), MINIO_ROOT_USER, MINIO_ROOT_PASSWORD
#          (required by minio + minio-init services), LITELLM_MASTER_KEY
#          (required by litellm service to boot in any mode).
#   Source: TECHNICAL_GUIDE §11.1; P00-S02-T001 task pack §D extensions table.
#
# SECURITY: Never commit real keys here. All values below are placeholders.
# Copy this file to .env and fill in real values for local development.

# ── Backend — TECHNICAL_GUIDE §11.1 ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://hilo:hilo@localhost:5432/hilo_dev
REDIS_URL=redis://localhost:6379/0
# JWT_PRIVATE_KEY / JWT_PUBLIC_KEY:
#   HS256 symmetric secret. RFC 7518 §3.2 requires ≥32 bytes for HS256.
#   In dev, scripts/gen-dev-secrets.sh (invoked by setup-from-scratch.sh)
#   will replace 'replace-with-dev-key' with a fresh
#     python3 -c "import secrets; print(secrets.token_urlsafe(48))"
#   value (~64 url-safe chars, ≥48 bytes entropy). Already-real keys are preserved.
#   Manual rotation: set value to 'replace-with-dev-key', rerun scripts/gen-dev-secrets.sh.
#   In staging/prod: inject via secrets manager; never commit real values here.
JWT_PRIVATE_KEY=replace-with-dev-key
JWT_PUBLIC_KEY=replace-with-dev-key
# ENCRYPTION_KEY: Fernet AEAD key for encrypting AI/MCP provider credentials at rest
# (ai_provider_credentials.encrypted_secret, mcp_credentials.encrypted_secret).
# In dev, scripts/gen-dev-secrets.sh (invoked by setup-from-scratch.sh) rotates
# 'replace-with-dev-key' to a fresh
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# value (44 url-safe base64 chars). Already-valid Fernet keys are preserved.
# Manual rotation: set value to 'replace-with-dev-key', rerun scripts/gen-dev-secrets.sh.
# In staging/prod: inject via secrets manager; never commit real values here.
# Ref: P02-S03-T004 D-T004-A1/A2; 01-non-negotiables.md §Security/External provider keys
ENCRYPTION_KEY=replace-with-dev-key
LITELLM_BASE_URL=http://litellm:4000
S3_BUCKET_DOCUMENTS=hilo-docs-dev
DEFAULT_LANGUAGE=es
MAX_UPLOAD_MB=25
MCP_ALLOWLIST_DOMAINS=localhost

# ── Postgres credentials (docker-compose.yml postgres service) ───────────────
# These map to POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB env vars
# consumed by the postgres:17-alpine image. Must match the host string in
# DATABASE_URL above (user=hilo, password=hilo, db=hilo_dev for local dev).
POSTGRES_USER=hilo
POSTGRES_PASSWORD=hilo
POSTGRES_DB=hilo_dev

# ── MinIO credentials (docker-compose.yml minio + minio-init services) ───────
# MINIO_ROOT_USER / MINIO_ROOT_PASSWORD are the admin credentials for the
# MinIO server. Also consumed by scripts/minio-bootstrap.sh to create the
# S3_BUCKET_DOCUMENTS bucket on first boot.
# SECURITY: Change these for any shared/staging/production environment.
MINIO_ROOT_USER=hilo
MINIO_ROOT_PASSWORD=hilo-dev-only

# ── LiteLLM gateway (docker-compose.yml litellm service) ─────────────────────
# LITELLM_MASTER_KEY is required for LiteLLM to start in proxy mode.
# Used to authenticate requests from the backend to the LiteLLM gateway.
# Must match LITELLM_MASTER_KEY env var declared in backend (Phase 2+).
# SECURITY: Use a strong random key in any shared/staging/production environment.
LITELLM_MASTER_KEY=sk-litellm-dev-only

# ── Observability — 01-non-negotiables.md §Logging ──────────────────────────
# true  → INFO+DEBUG visible (full BEFORE/AFTER flow per non-negotiables §Logging)
# false → WARNING+ERROR only
# In dev .env after setup-from-scratch.sh runs, this is forced to 'true'
# by scripts/gen-dev-secrets.sh so /verify-slice and dev-restart can see
# the full BEFORE/AFTER flow without manual env override.
# Set to 'false' in CI/staging to reduce noise.
# Placeholder kept as 'false' here so the template remains a conservative reference.
ENABLE_VERBOSE_LOGGING=false

# ── Ports (informational — not consumed directly as env vars) ────────────────
# Backend uvicorn:  http://localhost:8000  (STACK_PROFILE.yaml backend.health_url)
# Frontend Vite:    http://localhost:5173  (Vite default; declared in T002)
# Frontend nginx (compose): http://localhost:5173 (mapped from container :80)

# ── MFA + Secrets encryption (P00-S02-T003 — verification_data loader) ──────
# MFA_ENCRYPTION_KEY: Fernet key for encrypting MFA TOTP secrets and AI provider
# credentials at rest. Generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# This key is loaded by backend/app/verification_data/crypto.py -> encrypt_secret().
# P01-S01-T001 will use it for mfa_totp_secrets.secret_encrypted column.
# SECURITY: Keep this key secret. Rotate by re-encrypting all secrets.
# Ref: 01-non-negotiables.md §Security "Claves de proveedores externos"
MFA_ENCRYPTION_KEY=replace-with-fernet-key-from-generate_key

# ── Auth sign-up — corporate email domain whitelist (P01-S02-T001) ───────────
# Comma-separated list of corporate email domains allowed to register.
# FAIL-CLOSED: empty value = all domains rejected.
# Default includes all Inditex group domains + sandbox domain.
# CORPORATE_EMAIL_DOMAINS=inditex.com,inditex-sandbox.com,zara.com,zarahome.com,massimodutti.com,bershka.com,pullandbear.com,stradivarius.com,oysho.com,lefties.com

# ── Auth sign-up — rate limiting (P01-S02-T001) ───────────────────────────────
# Max sign-up attempts per IP per 60 seconds. 0 = disabled (not recommended).
# In-memory token bucket for V1; replaced by Redis in P02-S02-T001.
# AUTH_SIGNUP_RATE_PER_MINUTE=10
# AUTH_SIGNUP_RATE_BURST=10

# -- Auth sign-in -- JWT tokens and TTLs (P01-S02-T002) ----------------------
# JWT_ALGORITHM: Signing algorithm. HS256 for V1 (symmetric shared secret).
# Upgrade path to RS256: set JWT_PRIVATE_KEY=PEM-private-key, JWT_ALGORITHM=RS256.
JWT_ALGORITHM=HS256

# AUTH_ACCESS_TTL_SECONDS: Access token lifetime. 1800 = 30 min (TECHNICAL_GUIDE §10.2).
AUTH_ACCESS_TTL_SECONDS=1800

# AUTH_REFRESH_TTL_SECONDS: Refresh token lifetime. 2592000 = 30 days.
# Refresh token stored hashed in refresh_tokens.token_hash; rotated on each use (T003).
AUTH_REFRESH_TTL_SECONDS=2592000

# AUTH_MFA_CHALLENGE_TTL_SECONDS: MFA challenge JWT lifetime. 300 = 5 min.
AUTH_MFA_CHALLENGE_TTL_SECONDS=300

# -- Auth sign-in -- rate limiting (P01-S02-T002) ----------------------------
# Max sign-in attempts per IP per 60 seconds. In-memory V1; replaced by Redis P02-S02-T001.
# AUTH_SIGNIN_RATE_PER_MINUTE=20
# AUTH_SIGNIN_RATE_BURST=20

# -- Auth refresh -- rate limiting (P01-S02-T003) ----------------------------
# Max refresh calls per IP per 60 seconds. Refresh is normal authStore traffic;
# cap exists to block cookie-theft replay storms.
# In-memory V1; replaced by Redis P02-S02-T001.
# AUTH_REFRESH_RATE_PER_MINUTE=30
# AUTH_REFRESH_RATE_BURST=30


# -- Auth sign-in -- account lockout (P01-S02-T002) --------------------------
# Consecutive failures per user within window before 423 lockout.
# TODO(P02-S02-T001): replace audit-log scan with Redis counter.
# AUTH_SIGNIN_LOCKOUT_THRESHOLD=5
# AUTH_SIGNIN_LOCKOUT_WINDOW_SECONDS=900
# ── Auth password reset & mail (P01-S02-T005) ────────────────────────────────

# Mail provider: outbox (default dev/CI), resend, or smtp.
# In 'outbox' mode, emails are written to orchestrator-state/dev-logs/mail-outbox.jsonl
# instead of sending over the network. Tests use this mode by default.
MAIL_MODE=outbox

# Sender address for reset emails.
# MAIL_FROM=People <noreply@inditex-sandbox.com>

# Frontend base URL for reset link construction (reset URL = APP_BASE_URL/auth/reset?token=...).
# APP_BASE_URL=http://localhost:5173

# Resend API key (only required when MAIL_MODE=resend).
# RESEND_API_KEY=

# SMTP settings (only required when MAIL_MODE=smtp).
# MAIL_SMTP_HOST=
# MAIL_SMTP_PORT=587
# MAIL_SMTP_USER=
# MAIL_SMTP_PASS=

# Reset token TTL in seconds (default 1 hour).
# AUTH_RESET_TOKEN_TTL_SECONDS=3600

# Rate limiting for forgot-password endpoint (per IP per minute, in-memory V1).
# AUTH_FORGOT_RATE_PER_MINUTE=3

# Rate limiting for reset-password endpoint (per IP per minute).
# AUTH_RESET_RATE_PER_MINUTE=10

# Dev outbox path override (for testing with tmpdir).
# MAIL_OUTBOX_PATH=

# ── P01-S02-T006 — MFA 2FA verify rate limiting (WRITE_SET_DRIFT §D-MFA1.G) ──
# Rate limiting for POST /api/v1/auth/2fa/verify (per IP per minute, in-memory V1).
# Separate bucket from sign-in — a real user enters 6 digits in <60s.
# 20/min covers retries comfortably; burst 5 = "type-and-paste-twice".
# Default: 20/min, burst 5. Set to 0 to disable (for testing only).
# AUTH_MFA_VERIFY_RATE_PER_MINUTE=20
# AUTH_MFA_VERIFY_RATE_BURST=5

# TOTP valid_window: number of adjacent 30s steps accepted on each side.
# Default 1 = accepts current step ± 1 step (~90s window, RFC 6238 §5.2).
# AUTH_MFA_VERIFY_WINDOW=1
