# .env.example — Hilo People environment variable template
#
# Slice: P00-S01-T001 — Repo scaffold + scripts + env
# Phase: P00 — Scaffold + Design System
#
# HOW TO USE:
#   cp .env.example .env
#   Edit .env with real values for your environment.
#   .env is gitignored and must NEVER be committed (secrets must not appear in source).
#
# Variable naming reference:
#   - HILO_PEOPLE_TECHNICAL_GUIDE.md §2 (stack contract)
#   - scripts/dev-restart.profile.sh (port names: API_PORT, FRONT_PORT)
#   - docs/source-of-truth/STACK_PROFILE.yaml

# ---------------------------------------------------------------------------
# Server ports
# ---------------------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000
FRONT_PORT=5173

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_VERSION=0.1.0
ENABLE_VERBOSE_LOGGING=false

# ---------------------------------------------------------------------------
# Database (PostgreSQL + pgvector + pgcrypto)
# First migration added in P01-S01-T001; connection string format:
#   postgresql+asyncpg://user:password@host:5432/dbname
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://hilopeople:<change-me>@localhost:5432/hilopeople_dev

# ---------------------------------------------------------------------------
# Auth (JWT — implemented in P01-S02-T001)
# ---------------------------------------------------------------------------
JWT_SECRET=<change-me>
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=604800

# ---------------------------------------------------------------------------
# Redis / Celery (async jobs — added in T003)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# ---------------------------------------------------------------------------
# Security — provider key encryption (added in T003)
# Master key for Fernet-encrypted provider API keys stored in DB.
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ---------------------------------------------------------------------------
PROVIDER_ENCRYPTION_KEY=<change-me>

# ---------------------------------------------------------------------------
# LiteLLM (AI gateway — added in T003)
# ---------------------------------------------------------------------------
LITELLM_MASTER_KEY=<change-me>
LITELLM_PROXY_BASE_URL=http://localhost:4000

# ---------------------------------------------------------------------------
# Storage / S3-compatible (added in T003)
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=<change-me>
AWS_SECRET_ACCESS_KEY=<change-me>
AWS_REGION=eu-west-1
S3_BUCKET_RAG_DOCUMENTS=hilopeople-rag-documents-dev

# ---------------------------------------------------------------------------
# Mail (Resend — added in T003)
# ---------------------------------------------------------------------------
RESEND_API_KEY=<change-me>
MAIL_FROM_ADDRESS=noreply@hilopeople.example.com
MAIL_FROM_NAME=Hilo People

# ---------------------------------------------------------------------------
# CORS (comma-separated allowed origins for production)
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------------------------------------------------------------------------
# Observability (added in T003)
# ---------------------------------------------------------------------------
SENTRY_DSN=<change-me>
