# .env.example — Hilo People environment variables
# Copy this file to .env and fill in real values for your environment.
# NEVER commit .env to version control (see .gitignore).
# Slice: P00-S01-T001 — Repo scaffold + scripts + env.
#
# Sections:
#   1. App + logging
#   2. Database
#   3. Cache / Celery
#   4. Auth — JWT (asymmetric RS256, per TECHNICAL_GUIDE §10.2)
#   5. Encryption
#   6. CORS + ports
#   7. AI gateway (LiteLLM) — activated in P02+
#   8. Object storage (MinIO/S3) — activated in P04+
#   9. Email (Resend/SMTP) — activated in P01-S02+
#   10. i18n defaults
#   11. MCP security — activated in P04+

# ─────────────────────────────────────────────────────────────────────────────
# 1. App + logging
# ─────────────────────────────────────────────────────────────────────────────

# Application environment. One of: development | staging | production
APP_ENV=development

# Semantic version reported by /health. Override in CI/CD.
APP_VERSION=0.0.0

# Verbose logging flag.
# true  → DEBUG; shows full request/response flow including BEFORE/AFTER logs.
# false → WARNING/ERROR only (recommended for production).
ENABLE_VERBOSE_LOGGING=false

# ─────────────────────────────────────────────────────────────────────────────
# 2. Database
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL async connection URL (psycopg3 driver).
# Format: postgresql+psycopg://user:password@host:port/database
# Local Docker default — change user/password/name for your setup.
DATABASE_URL=postgresql+psycopg://hilo:hilo@localhost:5432/hilo_people

# ─────────────────────────────────────────────────────────────────────────────
# 3. Cache / Celery broker
# ─────────────────────────────────────────────────────────────────────────────

# Redis URL used both as Celery broker and optional cache.
REDIS_URL=redis://localhost:6379/0

# Celery task result backend (usually same as REDIS_URL or a different DB index).
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─────────────────────────────────────────────────────────────────────────────
# 4. Auth — JWT (asymmetric RS256, per TECHNICAL_GUIDE §10.2)
# ─────────────────────────────────────────────────────────────────────────────
# Generate with: openssl genrsa 2048 | tee private.pem; openssl rsa -in private.pem -pubout
# Store the PEM text with literal \n escapes in the env var.
# ACTIVATED: P01-S02-T001+

# RSA private key for signing access tokens (PEM format, one-liner with \n).
JWT_PRIVATE_KEY=change-me-generate-rsa-2048-private-pem

# RSA public key for verifying access tokens (PEM format, one-liner with \n).
JWT_PUBLIC_KEY=change-me-generate-rsa-2048-public-pem

# Access token TTL in seconds (default 15 min).
JWT_ACCESS_TTL_SECONDS=900

# Refresh token TTL in seconds (default 30 days).
JWT_REFRESH_TTL_SECONDS=2592000

# Algorithm for JWT signing. Must match the key type (RS256 for RSA).
JWT_ALGORITHM=RS256

# ─────────────────────────────────────────────────────────────────────────────
# 5. Encryption — AI provider credentials at rest
# ─────────────────────────────────────────────────────────────────────────────
# Used by the backend to encrypt/decrypt AI provider API keys stored in the DB.
# Must be a URL-safe base64-encoded 32-byte key (Fernet compatible).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ACTIVATED: P02-S01-T002+ (admin AI providers)
PROVIDER_ENCRYPTION_KEY=change-me-base64-32-bytes

# ─────────────────────────────────────────────────────────────────────────────
# 6. CORS + ports
# ─────────────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins for the backend.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Port the frontend Vite dev server listens on.
FRONTEND_PORT=5173

# Port the backend uvicorn server listens on.
BACKEND_PORT=8000

# ─────────────────────────────────────────────────────────────────────────────
# 7. AI gateway (LiteLLM)
# ─────────────────────────────────────────────────────────────────────────────
# ACTIVATED: P02-S01-T001+ (admin AI models)

# LiteLLM proxy base URL. In Docker Compose, use the service name.
LITELLM_BASE_URL=http://localhost:4000

# LiteLLM master key (used by backend to administer models via the proxy API).
LITELLM_MASTER_KEY=change-me

# ─────────────────────────────────────────────────────────────────────────────
# 8. Object storage (MinIO / S3-compatible)
# ─────────────────────────────────────────────────────────────────────────────
# ACTIVATED: P04-S01-T001+ (RAG document upload)

# S3-compatible endpoint URL. For local MinIO: http://localhost:9000
# S3_ENDPOINT_URL=http://localhost:9000

# Bucket name for RAG source documents.
# S3_BUCKET_DOCUMENTS=hilo-docs-dev

# AWS/MinIO credentials (use IAM roles or secret manager in production).
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin

# AWS region (set to us-east-1 for MinIO compatibility).
# AWS_DEFAULT_REGION=us-east-1

# ─────────────────────────────────────────────────────────────────────────────
# 9. Email (Resend primary, SMTP fallback)
# ─────────────────────────────────────────────────────────────────────────────
# ACTIVATED: P01-S02-T005+ (reset password / email verification)

# Resend API key. See resend.com/docs.
# RESEND_API_KEY=re_change-me

# From address for system emails.
# MAIL_FROM=noreply@hilo-people.com

# SMTP fallback (optional; used only if Resend is unavailable).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=change-me
# SMTP_PASSWORD=change-me

# ─────────────────────────────────────────────────────────────────────────────
# 10. i18n defaults
# ─────────────────────────────────────────────────────────────────────────────

# Default/fallback language for the application. One of: es | en | fr
DEFAULT_LANGUAGE=es

# Maximum allowed document upload size in MB (for RAG ingest, P04+).
MAX_UPLOAD_MB=25

# ─────────────────────────────────────────────────────────────────────────────
# 11. MCP security
# ─────────────────────────────────────────────────────────────────────────────
# ACTIVATED: P05-S01-T001+ (MCP server registry)

# Comma-separated list of allowed domains for external MCP servers.
# MCP_ALLOWLIST_DOMAINS=localhost
